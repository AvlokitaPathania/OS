#include <stdio.h>

#define LARGE_CONSTANT 10000 

typedef struct {
    int pid;
    int tickets;
    int stride;
    int pass;
    int remaining_time;
} Process;

// Improved find_winner logic
int find_winner(Process p[], int n) {
    int min_pass = 2147483647; // Max INT value
    int winner_idx = -1;

    for (int i = 0; i < n; i++) {
        if (p[i].remaining_time > 0) {
            // Pick the process with the lowest pass value
            if (p[i].pass < min_pass) {
                min_pass = p[i].pass;
                winner_idx = i;
            } 
            // Tie-breaker: if passes are equal, pick the one with more tickets (smaller stride)
            else if (p[i].pass == min_pass) {
                if (winner_idx == -1 || p[i].stride < p[winner_idx].stride) {
                    winner_idx = i;
                }
            }
        }
    }
    return winner_idx;
}

int main() {
    int n, total_burst = 0;
    
    printf("Enter number of processes: ");
    if (scanf("%d", &n) != 1 || n <= 0) return 1;

    Process p[n];

    for (int i = 0; i < n; i++) {
        p[i].pid = i + 1;
        printf("\n--- Process %d ---\n", i + 1);
        printf("Burst Time: ");
        scanf("%d", &p[i].remaining_time);
        printf("Tickets: ");
        scanf("%d", &p[i].tickets);
        
        // Stride is inversely proportional to tickets
        p[i].stride = LARGE_CONSTANT / p[i].tickets;
        p[i].pass = 0; 
        total_burst += p[i].remaining_time;
    }

    printf("\n%-10s %-10s %-20s\n", "Time", "Winner", "Pass Value Update");
    printf("----------------------------------------------\n");

    int current_time = 0;
    while (current_time < total_burst) {
        int idx = find_winner(p, n);
        
        if (idx == -1) break;

        printf("%-10d P%-9d %d -> %d\n", 
                current_time, p[idx].pid, p[idx].pass, p[idx].pass + p[idx].stride);

        // Increment pass by stride
        p[idx].pass += p[idx].stride;
        p[idx].remaining_time--;
        current_time++;
    }

    printf("----------------------------------------------\n");
    printf("Scheduling Complete.\n");

    return 0;
}
