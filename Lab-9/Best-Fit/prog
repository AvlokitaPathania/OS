#include <stdio.h>

int main() {
    int block[10], process[10];
    int nb, np, i, j, best;

    printf("Enter number of memory blocks: ");
    scanf("%d", &nb);

    printf("Enter sizes of blocks:\n");
    for(i = 0; i < nb; i++)
        scanf("%d", &block[i]);

    printf("Enter number of processes: ");
    scanf("%d", &np);

    printf("Enter sizes of processes:\n");
    for(i = 0; i < np; i++)
        scanf("%d", &process[i]);

    for(i = 0; i < np; i++) {
        best = -1;

        for(j = 0; j < nb; j++) {
            if(block[j] >= process[i]) {
                if(best == -1 || block[j] < block[best]) {
                    best = j;
                }
            }
        }

        if(best != -1) {
            printf("Process %d allocated to Block %d\n", i+1, best+1);
            block[best] = block[best] - process[i];
        }
    }

    return 0;
}
