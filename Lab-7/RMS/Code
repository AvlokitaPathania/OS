#include <stdio.h>

struct Process {
    int id;
    int execution_time;
    int period;
};

int main() {
    int n, i, j;
    struct Process p[10], temp;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    // Input process details
    for(i = 0; i < n; i++) {
        printf("\nEnter Execution Time for Process P%d: ", i + 1);
        scanf("%d", &p[i].execution_time);

        printf("Enter Period for Process P%d: ", i + 1);
        scanf("%d", &p[i].period);

        p[i].id = i + 1;
    }

    // Sort according to smaller period (higher priority)
    for(i = 0; i < n - 1; i++) {
        for(j = i + 1; j < n; j++) {
            if(p[i].period > p[j].period) {
                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    // Display RMS Scheduling Order
    printf("\nProcesses scheduled using Rate Monotonic Scheduling:\n");

    printf("\nProcess\tExecution Time\tPeriod\tPriority\n");

    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t\t%d\tHigh\n",
               p[i].id,
               p[i].execution_time,
               p[i].period);
    }

    return 0;
}
