#include <stdio.h>

#define LARGE_CONSTANT 10000 // To calculate stride

typedef struct {
    int pid;
    int tickets;
    int stride;
    int pass;
    int remaining_time;
} Process;

int find_winner(Process p[], int n) {
    int min_pass = 1e9; // Large value
    int winner_idx = -1;

    for (int i = 0; i < n; i++) {
        if (p[i].remaining_time > 0) {
            if (p[i].pass < min_pass) {
                min_pass = p[i].pass;
                winner_idx = i;
            }
        }
    }
    return winner_idx;
}

int main() {
    int n, total_burst = 0;
    printf("Enter number of processes: ");
    scanf("%d", &n);

    Process p[n];

    for (int i = 0; i < n; i++) {
        p[i].pid = i + 1;
        printf("\nProcess %d - Enter Burst Time: ", i + 1);
        scanf("%d", &p[i].remaining_time);
        printf("Process %d - Enter Tickets: ", i + 1);
        scanf("%d", &p[i].tickets);
        
        // Calculate stride: Higher tickets = Smaller stride
        p[i].stride = LARGE_CONSTANT / p[i].tickets;
        p[i].pass = 0;
        total_burst += p[i].remaining_time;
    }

    printf("\n--- Scheduling Sequence ---\n");
    printf("Time\tWinner\tPass Value Update\n");
    printf("----------------------------------\n");

    int current_time = 0;
    while (current_time < total_burst) {
        int idx = find_winner(p, n);
        if (idx == -1) break;

        printf("%d\tP%d\tPass: %d -> %d\n", 
                current_time, p[idx].pid, p[idx].pass, p[idx].pass + p[idx].stride);

        p[idx].pass += p[idx].stride;
        p[idx].remaining_time--;
        current_time++;
    }

    return 0;
}
