#include <stdio.h>
#include <stdbool.h>

int main() {
    // P = Number of processes, R = Number of resources
    int P = 5, R = 3;
    int i, j, k;

    // Allocation Matrix
    int alloc[5][3] = { { 0, 1, 0 },    // P0
                        { 2, 0, 0 },    // P1
                        { 3, 0, 2 },    // P2
                        { 2, 1, 1 },    // P3
                        { 0, 0, 2 } };  // P4

    // MAX Matrix
    int max[5][3] = { { 7, 5, 3 },      // P0
                      { 3, 2, 2 },      // P1
                      { 9, 0, 2 },      // P2
                      { 2, 2, 2 },      // P3
                      { 4, 3, 3 } };    // P4

    // Available Resources
    int avail[3] = { 3, 3, 2 }; 

    int f[P], ans[P], ind = 0;
    for (k = 0; k < P; k++) {
        f[k] = 0;
    }

    // Need Matrix calculation: Need[i][j] = Max[i][j] - Alloc[i][j]
    int need[P][R];
    for (i = 0; i < P; i++) {
        for (j = 0; j < R; j++)
            need[i][j] = max[i][j] - alloc[i][j];
    }

    int y = 0;
    for (k = 0; k < 5; k++) {
        for (i = 0; i < P; i++) {
            if (f[i] == 0) {
                int flag = 0;
                for (j = 0; j < R; j++) {
                    if (need[i][j] > avail[j]) {
                        flag = 1;
                        break;
                    }
                }

                if (flag == 0) {
                    ans[ind++] = i;
                    for (y = 0; y < R; y++)
                        avail[y] += alloc[i][y];
                    f[i] = 1;
                }
            }
        }
    }

    bool safe = true;
    for(i = 0; i < P; i++) {
        if(f[i] == 0) {
            safe = false;
            printf("The system is not safe.");
            break;
        }
    }

    if(safe) {
        printf("Following is the SAFE Sequence:\n");
        for (i = 0; i < P - 1; i++)
            printf(" P%d ->", ans[i]);
        printf(" P%d\n", ans[P - 1]);
    }

    return (0);
}
